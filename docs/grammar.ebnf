(* ============================================================================
   Radahn v0 — formal grammar (EBNF)
   ============================================================================

   Status:   v0 surface syntax, frozen for Epic 0.4 (lexer + parser).
   Source:   docs/Design.md §4 (lexical + grammatical rules), §5 (worked
             examples), §11.8 (extern / TS interop).
   Flavour:  W3C-style EBNF — `::=` for production, `|` for alternation,
             `?` `*` `+` for quantifiers, parentheses for grouping,
             double-quoted strings for literal terminals, ALL-CAPS names
             for lexical tokens, CamelCase names for syntactic non-terminals.

   Pinned canonical forms (where Design.md showed two):

     - Generic type arguments:   `[` `]`        NOT `<` `>`
       (`<` `>` clashes with comparison operators — LR(1)-unfriendly.)
     - Module header:            full block with `end-module`
       (the `module foo/bar@1.2` shorthand from §8.5.2 is NOT accepted.)
     - Effect row:               `! { name, name }`    (braced, comma-sep)
       (the `! Fs<write>, Net<https>` form from §5.1 is NOT accepted.)
     - ADT sum variant lead:     leading `|` required on every arm
       (including the first; reserves bare-`|`-expressions for future
       lambda / closure syntax.)
     - Statement terminator:     NEWLINE inside `{ }` (no semicolons)
     - Contract clauses:         parsed in v0, checked in v1 (Epic 1.3)
     - Refinement clauses:       parsed in v0, checked in v2 (Epic 2.2)

   Disambiguation rules are listed at the bottom of this file (R1–R13)
   with their resolution strategy.  Two rules (R2, R11) require a
   bounded 2-token lookahead from the decision point — a documented
   deviation from Design §4.2's "1-token" wording.  All other rules
   resolve under standard LR(1).
   ============================================================================ *)


(* ----------------------------------------------------------------------------
   1.  Lexical grammar — terminals
   ----------------------------------------------------------------------------

   The lexer emits the tokens below.  Whitespace and comments are skipped
   except where NEWLINE is significant (see §1.5).  Identifiers and
   keywords share a character class; a reserved-word table is consulted
   after the longest-match rule picks the token text.
*)

(* 1.1 Identifiers *)

IDENT        ::= IDENT_START IDENT_CONT*
IDENT_START  ::= "a".."z" | "A".."Z" | "_"
IDENT_CONT   ::= IDENT_START | "0".."9"

(* Type identifiers share the IDENT token class.  The parser distinguishes
   them positionally: a TYPE_IDENT is any IDENT in a type-production slot.
   By convention (enforced by `radahn fmt`, not the grammar) type names
   begin with an upper-case letter. *)


(* 1.2 Keywords (reserved — cannot appear as IDENT)

   Listed from Design §4.2 plus `end-module`, `return`, `extern`, `pub`,
   `else`, which appear in worked examples (§5.1, §8.5.2, §11.8).  See
   the trailing note for the IDENT-but-restricted cases (`pre`, `post`,
   `cost`, `for`, `in`, `true`, `false`). *)

KEYWORD ::=
      "fn"      | "let"      | "if"      | "else"
    | "match"   | "module"   | "end-module"
    | "import"  | "export"   | "extern"  | "pub"
    | "effect"  | "cap"
    | "type"    | "trait"    | "impl"
    | "where"
    | "spec"    | "test"
    | "partial" | "linear"
    | "return"

(* `pre`, `post`, `cost` are NOT global keywords — they are contextual,
   recognised only in the position immediately after `@` (see ContractClause
   in §3.1).  This keeps them usable as ordinary identifiers elsewhere
   (e.g. a field named `cost`).

   `for`, `in` are reserved-for-future-use.  They have no syntactic
   production in v0; encountering them at any position raises E0101
   (unexpected token).  `for`-loops land in v1 (Epic 1.1 / stdlib work).

   `true`, `false` are NOT keywords — they are the BOOL_LIT terminal
   below.  Treating them as literals (not keywords) keeps the lexer rule
   for them in one place. *)


(* 1.3 Literal tokens *)

INT_LIT      ::= DEC_LIT | HEX_LIT | OCT_LIT | BIN_LIT
DEC_LIT      ::= ("0" | "1".."9" ("_"? "0".."9")*)
HEX_LIT      ::= "0x" ("0".."9" | "a".."f" | "A".."F") (("_" | "0".."9" | "a".."f" | "A".."F"))*
OCT_LIT      ::= "0o" ("0".."7") (("_" | "0".."7"))*
BIN_LIT      ::= "0b" ("0" | "1") (("_" | "0" | "1"))*

FLOAT_LIT    ::= DEC_LIT "." DEC_LIT (("e" | "E") ("+" | "-")? DEC_LIT)?
               | DEC_LIT ("e" | "E") ("+" | "-")? DEC_LIT

STRING_LIT   ::= "\"" (STRING_CHAR | ESCAPE)* "\""
STRING_CHAR  ::= ? any UTF-8 scalar except "\"", "\\", or NEWLINE ?
ESCAPE       ::= "\\" ("\"" | "\\" | "n" | "r" | "t" | "0"
                       | "x" HEX HEX
                       | "u" "{" HEX+ "}")
HEX          ::= "0".."9" | "a".."f" | "A".."F"

BOOL_LIT     ::= "true" | "false"


(* 1.4 Operators and punctuation *)

OP           ::=
      "+"  | "-"  | "*"  | "/"  | "%"
    | "==" | "!=" | "<"  | "<=" | ">"  | ">="
    | "&&" | "||" | "!"  | "?"
    | "="  | "->" | "=>" | "::" | ".."
    | "++"                                    (* string/list concat, §8.5.2 *)
    | ","  | "."  | ";"  | ":"
    | "("  | ")"  | "["  | "]"  | "{"  | "}"
    | "|"
    | "@"                                     (* contract-clause prefix *)


(* 1.5 Whitespace, comments, newlines *)

WS           ::= (" " | "\t")+               (* non-significant *)
NEWLINE      ::= "\r"? "\n"

LINE_COMMENT ::= "//"   (? any char except NEWLINE ?)* NEWLINE
DOC_COMMENT  ::= "///"  (? any char except NEWLINE ?)* NEWLINE
HINT_COMMENT ::= "//@"  (? any char except NEWLINE ?)* NEWLINE

(* NEWLINE is a statement terminator INSIDE `{ … }` blocks.
   NEWLINE is plain whitespace INSIDE `( … )` or `[ … ]` (so long
   argument lists and long type lists may wrap).
   Comments always act as whitespace (DOC_COMMENT is attached to the
   next declaration by the parser, not the grammar). *)


(* ----------------------------------------------------------------------------
   2.  Syntactic grammar — top level
   ----------------------------------------------------------------------------
*)

File         ::= ModuleHeader TopDecl*

ModuleHeader ::= "module" ModulePath NEWLINE
                 ModuleField*
                 "end-module" NEWLINE

ModulePath   ::= IDENT ("." IDENT | "/" IDENT)*

ModuleField  ::=
      "version" ":" STRING_LIT NEWLINE
    | "exports" ":" "[" IdentList? "]" NEWLINE
    | "effects" ":" "[" EffectName ("," EffectName)* "]" NEWLINE
    | "caps"    ":" "[" IdentList? "]" NEWLINE
    | "since"   ":" STRING_LIT NEWLINE
    | "summary" ":" STRING_LIT NEWLINE

(* `exports` is required on non-empty modules — checked semantically
   (diagnostic E0601 / E0204), not here, so the grammar accepts any order
   and any subset. *)

IdentList    ::= IDENT ("," IDENT)*


(* ----------------------------------------------------------------------------
   3.  Top-level declarations
   ----------------------------------------------------------------------------
*)

TopDecl      ::= Import
               | Visibility? FnDecl
               | Visibility? TypeDecl
               | ExternBlock

Visibility   ::= "pub"

Import       ::= "import" ModulePath ("{" IdentList "}")? NEWLINE


(* 3.1 Function declarations *)

FnDecl       ::= "fn" IDENT
                 TypeParams?
                 "(" ParamList? ")"
                 ("->" Type)?
                 EffectRow?
                 ContractClause*
                 (Block | NEWLINE)

ParamList    ::= Param ("," Param)* ","?
Param        ::= IDENT ":" Type

TypeParams   ::= "[" IDENT ("," IDENT)* "]"

EffectRow    ::= "!" "{" (EffectName ("," EffectName)*)? "}"
EffectName   ::= IDENT ("." IDENT)*             (* e.g. `fs.read` *)

ContractClause ::=
      "@" ContractName ContractBody NEWLINE

ContractName ::= "pre" | "post" | "cost"
                 (* Contextual: the lexer emits IDENT for these strings;
                    the parser, immediately after consuming `@`, accepts
                    ONLY this closed set.  Any other IDENT after `@`
                    fires E0501 (malformed contract clause) with a
                    suggestion listing the legal names.  This is the
                    only place E0501 is reached; everywhere else, a
                    syntactically broken `@…` falls through to E0101. *)

ContractBody ::= CostFields                     (* iff ContractName = "cost" *)
               | Expr                           (* iff ContractName = "pre" or "post" *)

CostFields   ::= CostField ("," CostField)*
CostField    ::= IDENT ":" CostValue
CostValue    ::= ("<=" | "~")? (INT_LIT | FLOAT_LIT) IDENT?
               (* examples: `tokens: 120`, `ops: ~6`, `time <= 5s` *)


(* 3.2 Type declarations *)

TypeDecl     ::= "type" IDENT TypeParams? "=" TypeExpr NEWLINE

TypeExpr     ::= SumType
               | Type

SumType      ::= ("|" Variant)+
                 (* ≥ 1 variant; a one-variant sum is legal but warned at
                    a later pass (no diagnostic in v0).  The leading `|`
                    is required on every arm — see R3. *)
Variant      ::= IDENT ("(" VariantPayload ")")?
VariantPayload ::= Type ("," Type)*
                 | FieldList                    (* named payload *)


(* 3.3 Type expressions *)

Type         ::= TypeAtom ("where" Expr)?       (* refinement — parsed only *)

TypeAtom     ::= NominalType
               | RecordType
               | TupleType
               | FnType
               | "(" Type ")"
               | "(" ")"                        (* unit *)

NominalType  ::= IDENT ("." IDENT)* TypeArgs?
TypeArgs     ::= "[" Type ("," Type)* "]"

RecordType   ::= "{" FieldList? "}"
FieldList    ::= Field ("," Field)* ","?
Field        ::= IDENT ":" Type

TupleType    ::= "(" Type "," Type ("," Type)* ")"

FnType       ::= "fn" "(" (Type ("," Type)*)? ")" "->" Type EffectRow?


(* 3.4 Extern blocks (§11.8) *)

ExternBlock  ::= "extern" "module" ModulePath "{" NEWLINE
                 ExternDecl*
                 "}" NEWLINE

ExternDecl   ::= "fn" IDENT "(" ParamList? ")" ("->" Type)? EffectRow? NEWLINE
               | "type" IDENT TypeParams? NEWLINE       (* opaque *)


(* ----------------------------------------------------------------------------
   4.  Statements and blocks
   ----------------------------------------------------------------------------
*)

Block        ::= "{" NEWLINE Stmt* "}"

Stmt         ::= LetStmt
               | ReturnStmt
               | ExprStmt

LetStmt      ::= "let" Pattern (":" Type)? "=" Expr NEWLINE
ReturnStmt   ::= "return" Expr? NEWLINE
ExprStmt     ::= Expr NEWLINE


(* ----------------------------------------------------------------------------
   5.  Patterns (for `let` and `match`)
   ----------------------------------------------------------------------------
*)

Pattern      ::= WildcardPat
               | LiteralPat
               | NamePat
               | RecordPat
               | TuplePat

WildcardPat  ::= "_"
LiteralPat   ::= INT_LIT | FLOAT_LIT | STRING_LIT | BOOL_LIT
NamePat      ::= IDENT ("(" Pattern ("," Pattern)* ")")?
                 (* See R12: bare IDENT is a binding *iff* its initial
                    letter is lower-case; `IDENT(...)` (with payload) is
                    always a constructor pattern.  Capitalised bare
                    IDENT is a nullary constructor pattern. *)
RecordPat    ::= "{" (RecordPatField ("," RecordPatField)*)? "}"
RecordPatField ::= IDENT (":" Pattern)?             (* shorthand: `{ x }` *)
TuplePat     ::= "(" Pattern "," Pattern ("," Pattern)* ")"


(* ----------------------------------------------------------------------------
   6.  Expressions — precedence-climb
   ----------------------------------------------------------------------------

   Loosest-binding at the top; tightest at the bottom.  Each level accepts
   the level below, so the precedence is enforced structurally.
*)

Expr         ::= OrExpr
               | IfExpr
               | MatchExpr

OrExpr       ::= AndExpr    ("||" AndExpr)*
AndExpr      ::= CmpExpr    ("&&" CmpExpr)*
CmpExpr      ::= RangeExpr  (CmpOp RangeExpr)?
CmpOp        ::= "==" | "!=" | "<" | "<=" | ">" | ">="

RangeExpr    ::= AddExpr (".." AddExpr)?            (* e.g. `0..3` *)
AddExpr      ::= MulExpr (("+" | "-" | "++") MulExpr)*
MulExpr      ::= UnaryExpr (("*" | "/" | "%") UnaryExpr)*

UnaryExpr    ::= ("-" | "!") UnaryExpr
               | PostfixExpr

PostfixExpr  ::= PrimaryExpr PostfixOp*
PostfixOp    ::= CallArgs
               | "." IDENT
               | "[" Expr "]"
               | "?"
               | "::" TypeArgs                     (* turbofish, e.g. decode::[T] *)

CallArgs     ::= "(" (Arg ("," Arg)* ","?)? ")"
Arg          ::= IDENT "=" Expr                    (* named *)
               | Expr                              (* positional *)

PrimaryExpr  ::= Literal
               | IDENT
               | "(" Expr ")"
               | TupleExpr
               | RecordExpr
               | ListExpr
               | Block                             (* block-as-expression *)

Literal      ::= INT_LIT | FLOAT_LIT | STRING_LIT | BOOL_LIT | "(" ")"

TupleExpr    ::= "(" Expr "," Expr ("," Expr)* ")"
RecordExpr   ::= IDENT? "{" (RecordInit ("," RecordInit)* ","?)? "}"
RecordInit   ::= IDENT ":" Expr
               | IDENT                              (* shorthand `{ x }` *)
ListExpr     ::= "[" (Expr ("," Expr)* ","?)? "]"


(* 6.1 if / match as expressions *)

IfExpr       ::= "if" Expr Block ("else" (IfExpr | Block))?

MatchExpr    ::= "match" Expr "{" NEWLINE MatchArm+ "}"
MatchArm     ::= Pattern ("if" Expr)? "=>" (Expr | Block) NEWLINE


(* ----------------------------------------------------------------------------
   7.  Disambiguation rules — the non-LR(1) cases and how we resolve them
   ----------------------------------------------------------------------------

   EBNF alone cannot express these; the parser enforces them.  Most rules
   are discharged with one token of lookahead past the ambiguous position,
   keeping Radahn within standard LR(1) parser-generator capability.

   Two rules require a bounded *two*-token lookahead from the decision
   point: R2 (turbofish `::` + `[`) and R11 (`{` + first token inside).
   This is a documented deviation from Design §4.2's "1-token" wording —
   in practice every mainstream LR(1) generator (Bison, Menhir, Lark,
   Chevrotain) supports bounded extra lookahead via either GLR fallback
   or k-token modes, and both sites have a hard 2-token bound (no
   arbitrary lookahead is ever required).  Design §4.2 should be amended
   to read "LR(1) with two documented 2-token lookahead sites" once
   Epic 0.4 picks a generator and confirms the choice.

   R1.  `[` after IDENT — generic args vs. list-index.
        Resolution: the grammar never permits an expression in a type-only
        slot, so `[` following an IDENT that was parsed as `NominalType`
        opens `TypeArgs`; `[` following an IDENT that was parsed as an
        `Expr` primary opens an index `PostfixOp`.  No lookahead past `[`
        is required because the production context is fixed before we
        reach `[`.

   R2.  Turbofish for explicit type arguments at a call site.
        `decode::[T]` (NOT `decode::<T>`) — the turbofish reuses the
        canonical `[ ]` generic delimiters chosen in the header.  In
        expression context, a bare `foo[T]` is always an index/subscript
        (`PostfixOp` `"[" Expr "]"`); to pass an explicit type argument
        the caller must prefix with `::`.  The two-token sequence
        `::` `[` is unambiguous because `::` has no other use in
        expression context in v0.

   R3.  ADT variants lead with `|`.
        `type T = | A | B` (leading `|` required, even on the first arm).
        A type RHS beginning with `|` is unambiguously a `SumType`;
        a type RHS beginning with `{`, `(`, or IDENT is unambiguously a
        non-sum `Type`.

   R4.  NEWLINE as statement terminator.
        Inside `{ … }`:  NEWLINE ends the current Stmt, unless the parser
        is inside an unclosed `(`, `[`, or open `match` arm.
        Inside `( … )` / `[ … ]`:  NEWLINE is plain whitespace.
        A single counter of "open paren/bracket depth" is sufficient; no
        arbitrary lookahead is needed.

   R5.  `=` in call-argument position is a named argument, never
        assignment.  Radahn v0 has no assignment expression; once the
        parser is inside a `CallArgs`, seeing IDENT followed by `=` always
        starts a named `Arg`.  Outside call args, `=` appears only in
        `let`, `type`, and ModuleField productions, all of which are
        entered from distinct keywords, so no ambiguity arises.

   R6.  `-` unary vs. binary.
        Resolved by precedence-climb structure: `-` is binary only in
        `AddExpr`, unary only in `UnaryExpr`.  Reading `-` after a complete
        primary / postfix expression is binary; reading `-` at the start
        of an `Expr` or after another operator is unary.

   R7.  `?` is always postfix.
        The grammar never permits `?` in infix position; it appears only
        as a `PostfixOp`.  `foo()?.bar` parses as `((foo())?).bar`.

   R8.  `where` — refinement vs. constraint.
        In v0, `where` appears only in a `Type` production (refinement
        clause).  The generic-constraint use-site (`fn f[T](x: T) where
        T: Ord`) is *not* accepted in v0; it is reserved and will be
        added in Epic 1.1 without grammar breakage because the only new
        position is between `)` (or `-> Type`) and the function body.

   R9.  `else if` chains.
        `IfExpr ::= … ("else" (IfExpr | Block))?` handles `else if`
        without a dedicated `elif` keyword.  The right-recursion is
        unambiguous under LR(1).

   R10. `!` — unary "not" vs. effect-row introducer.
        `!` is the effect-row introducer only at the end of a function
        signature (directly after `)` or `-> Type`).  Elsewhere it is
        unary "not".  The parser enters the EffectRow production only
        from FnDecl / ExternDecl / FnType — these are the only sites
        where `!` can legally mean "effects"; any other `!` is unary.

   R11. `{ … }` — block vs. record literal.
        `Block` requires NEWLINE immediately after `{`:
            `Block       ::= "{" NEWLINE Stmt* "}"`
            `RecordExpr  ::= IDENT? "{" RecordInit ("," RecordInit)* ","? "}"`
        The first token after `{` decides:
          - NEWLINE            → `Block`
          - IDENT `:`          → `RecordExpr` (anonymous record)
          - `}`                → `RecordExpr` (empty record; an empty
                                  block would have a NEWLINE before `}`)
        Two-token lookahead (`{` plus one token) is sufficient.

        A RecordExpr with leading IDENT (`RefundReceipt { … }`) is
        disallowed in the scrutinee position of `if`, `while`, `for`,
        and `match` to avoid ambiguity with the Block that follows the
        scrutinee (compare Rust's "struct-literal in condition" rule).
        In those positions, the grammar requires parentheses around any
        expression ending in `{ … }`.

   R12. `IDENT` in pattern position — binding vs. constructor.
        A pattern position accepts `NamePat ::= IDENT ("(" … ")")?`.
        Disambiguation by case convention (Rust-style):
          - Bare IDENT, initial letter lower-case      → binding
          - Bare IDENT, initial letter upper-case      → nullary ctor
          - IDENT followed by `(`                      → ctor with payload
            (regardless of case — name resolution will reject lower-case
            ctor names with a better error than the parser could give)
          - `_`                                        → WildcardPat
        Convention is enforced at parse time so the AST records the
        intended pattern kind.  An upper-case binding (e.g. `let X = 1`)
        is rejected with E0101 / E0202; a lower-case ctor reference
        (e.g. `match v { ok(x) => … }`) parses but resolves to E0201
        (unknown identifier) at name-resolution time.

   R13. NEWLINE inside a `TypeDecl` RHS.
        Between `=` and the end of `TypeExpr` in a `TypeDecl`, NEWLINE is
        treated as whitespace (analogous to R4's behaviour inside `( )`
        and `[ ]`).  This permits the canonical multi-line ADT layout:
            `type T =`
            `  | A`
            `  | B`
        The TypeDecl is terminated by the NEWLINE that follows the last
        Variant of the SumType (or the closing token of a non-sum
        TypeAtom — e.g. `}` for a record, `)` for a tuple).  The parser
        re-enables NEWLINE significance the moment `TypeExpr` is
        recognised as complete.  No additional lookahead is required
        beyond the depth counter R4 already maintains.

   ============================================================================ *)

(* end of file *)
